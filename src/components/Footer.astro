---
const currentYear = new Date().getFullYear();
---
<footer class="main-footer">
  <div class="container footer-container">
    <div class="footer-brand">
      <a href="#" class="logo-link">
        <img src="/images/logo.jpg" alt="RightSec Logo" class="logo-img" />
        <span class="logo-text">Right<span class="logo-accent">Sec</span></span>
      </a>
      <p class="brand-tagline">
        Fortifying organizations against cyber threats through expert-level security engineering and strategic defense architectures.
      </p>
    </div>

    <div class="footer-links">
      <h4 class="links-title">Quick Navigation</h4>
      <div class="links-grid">
        <a href="#">Home</a>
        <a href="#services">Services</a>
        <a href="#about">About Us</a>
        <a href="#contact">Contact</a>
      </div>
    </div>

    <div class="footer-security">
      <h4 class="links-title">Defense Standards</h4>
      <div class="security-badges">
        <span class="badge"><i class="fa-solid fa-lock text-accent"></i> TLS Encrypted</span>
        <span class="badge"><i class="fa-solid fa-user-shield text-accent"></i> CIS Controls</span>
        <span class="badge"><i class="fa-solid fa-file-shield text-accent"></i> ISO Compliance</span>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-container">
      <p>&copy; {currentYear} RightSec. All rights reserved. Secured and hosted on Cloudflare Pages.</p>
      <div class="social-links">
        <a href="https://wa.me/50687079515" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"><i class="fa-brands fa-whatsapp"></i></a>
        <a href="mailto:info@rightsec.com" aria-label="Email"><i class="fa-solid fa-envelope"></i></a>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background-color: var(--color-bg-darkest);
    border-top: 1px solid rgba(0, 181, 226, 0.08);
    padding: 5rem 0 0 0;
    color: var(--color-text-secondary);
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .logo-img {
    height: 35px;
    width: auto;
    border-radius: 4px;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.5px;
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .brand-tagline {
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 350px;
  }

  .links-title {
    font-size: 1.05rem;
    color: #ffffff;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .links-grid {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    font-size: 0.9rem;
  }

  .links-grid a:hover {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  .security-badges {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .badge {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #ffffff;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
  }

  /* Bottom Bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    padding: 2rem 0;
    background: rgba(4, 6, 15, 0.5);
    font-size: 0.85rem;
  }

  .bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: 1rem;
    transition: var(--transition-smooth);
  }

  .social-links a:hover {
    background: var(--color-accent);
    color: var(--color-bg-darkest);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .bottom-container {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
